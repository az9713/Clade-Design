{
  "name": "clade-design",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "description": "The design platform that learns your brand — and gets better every time you use it.",
  "license": "MIT",
  "bin": {
    "clade": "./apps/daemon/dist/cli.js"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.mjs",
    "build": "pnpm --filter @clade/web build",
    "check:residual-js": "node --experimental-strip-types scripts/check-residual-js.ts",
    "sync:community-pets": "node --experimental-strip-types scripts/sync-community-pets.ts",
    "bake:community-pets": "node --experimental-strip-types scripts/bake-community-pets.ts",
    "test:e2e:live": "pnpm --filter @clade/e2e test:e2e:live",
    "test": "pnpm -r --workspace-concurrency=1 --if-present run test",
    "test:ui:clean": "pnpm --filter @clade/e2e test:ui:clean",
    "test:ui": "pnpm --filter @clade/e2e test:ui",
    "test:ui:headed": "pnpm --filter @clade/e2e test:ui:headed",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present run typecheck && pnpm --filter @clade/daemon build && pnpm check:residual-js"
  },
  "devDependencies": {},
  "engines": {
    "node": "~24",
    "pnpm": ">=10.33.2 <11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
